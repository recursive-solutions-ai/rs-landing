# ─── Brain Connection ────────────────────────────────────────────────────────
# Get these from the Brain admin portal.
# Without these, forms and CRM integration will not be connected.
BRAIN_API_URL=
BRAIN_API_KEY=

# ─── Turso Database ──────────────────────────────────────────────────────────
# Provisioned per-tenant from the Brain portal.
# Without these, the blog system will not work.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── Site URL ────────────────────────────────────────────────────────────────
# Used for sitemap.xml and robots.txt (optional)
# SITE_URL=https://your-domain.com

# ─── Google Analytics ────────────────────────────────────────────────────────
# Optional — no tracking if omitted
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Internationalization ────────────────────────────────────────────────────
# Optional — defaults to English-only if omitted
# DEFAULT_LANGUAGE=en
# ADDITIONAL_LANGUAGES=fr,es,de
